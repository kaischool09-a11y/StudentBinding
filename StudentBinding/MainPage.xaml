<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StudentBinding.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="30,0" Spacing="25">

            <!--  תמונת פרופיל  -->
            <Image
                Aspect="AspectFit"
                HeightRequest="185"
                SemanticProperties.Description="Student profile image"
                Source="{Binding DisplayedStudent.ImageSource}" />
            <!--  שם התלמיד  -->
            <Label
                FontAttributes="Bold"
                FontSize="32"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="{Binding DisplayedStudent.Name, StringFormat='שם: {0}'}"
                TextColor="MidnightBlue" />
            <!--  גיל  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student age"
                SemanticProperties.HeadingLevel="Level2"
                Text="16"
                TextColor="MidnightBlue" />

            <!--  תאריך לידה  -->
            <DatePicker
                Date="{Binding DisplayedStudent.BirthDate}"
                FontSize="24"
                HorizontalOptions="Center"
                TextColor="MidnightBlue" />

            <Button 
                Text="החלף סטודנט מוצג" 
                Clicked="StudentSwitchClick" 
                BackgroundColor="DarkBlue"
                TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>